{
  "name": "harness-maturity-analysis",
  "private": true,
  "version": "0.1.0",
  "description": "A reproducible, deterministic study of AI-harness maturity across notable open-source repositories — scored with harness-score, checked against blind human review.",
  "type": "module",
  "scripts": {
    "corpus:run": "node corpus/run.mjs",
    "corpus:build": "node corpus/build-results.mjs",
    "site:build": "node corpus/build-site.mjs",
    "corpus": "npm run corpus:run && npm run corpus:build && npm run site:build",
    "score": "node corpus/score-adhoc.mjs",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paladini/harness-maturity-analysis.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "harness-score": "^1.3.2",
    "husky": "^9.1.7",
    "vitest": "^3.0.0"
  }
}
